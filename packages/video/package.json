{
  "name": "@kv/video",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preview": "remotion studio src/Root.tsx",
    "render:hero": "remotion render src/Root.tsx HeroIntro ../../apps/web/public/videos/hero-intro.mp4 --codec h264",
    "render:stats": "remotion render src/Root.tsx StatsCounter ../../apps/web/public/videos/stats-counter.mp4 --codec h264",
    "render:features": "remotion render src/Root.tsx FeatureReveal ../../apps/web/public/videos/feature-reveal.mp4 --codec h264",
    "render:all": "pnpm render:hero && pnpm render:stats && pnpm render:features"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "remotion": "^4.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.0.0"
  }
}
